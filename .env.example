# Database Configuration
DB_TYPE=supabase
DATABASE_URL=postgresql://postgres.[PROJECT_ID]:[YOUR_PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Active Keys (JWT format for PHP SDK)
# SUPABASE_SECRET_KEY=[YOUR_JWT_SECRET_KEY]
# SUPABASE_PUBLISHABLE_KEY=[YOUR_JWT_PUBLISHABLE_KEY]

# Legacy Keys (New API format - kept for reference)
SUPABASE_SECRET_KEY=[YOUR_SECRET_KEY]
SUPABASE_PUBLISHABLE_KEY=[YOUR_PUBLISHABLE_KEY]

SUPABASE_PROJECT_URL=https://[PROJECT_ID].supabase.co
SUPABASE_REFERENCE_ID=[PROJECT_ID]

# Performance Optimization Settings
SUPABASE_CONNECTION_TIMEOUT=5
SUPABASE_READ_TIMEOUT=10
SUPABASE_POOL_SIZE=10
SUPABASE_POOL_TIMEOUT=30

# SSL Configuration
SUPABASE_SSL_MODE=verify-full
SUPABASE_SSL_CERT_PATH=/path/to/cacert.pem

APP_TIMEZONE=Asia/Jakarta

# Cookie configuration for Remember Me functionality
COOKIE_SECRET_KEY=[GENERATE_RANDOM_SECRET_KEY]